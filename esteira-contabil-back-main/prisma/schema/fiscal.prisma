model fis_empresas {
  id                         String                       @id @default(uuid())
  dt_created                 DateTime                     @default(now())
  dt_updated                 DateTime                     @default(now()) @updatedAt
  id_sis_empresas            String                       @unique
  sis_empresas               sis_empresas                 @relation(fields: [id_sis_empresas], references: [id])
  fis_segmentos_empresas     fis_segmentos_empresas[]
  fis_prd_segmento           fis_prd_segmento[]
  fis_produtos               fis_produtos[]
  fis_nfse                   fis_nfse[]
  fis_nfse_emitente          fis_nfse[]                   @relation("NfseEmpresaEmitente")
  fis_documento              fis_documento[]
  fis_fornecedores           fis_fornecedores[]
  fis_empresas_tecnospeed    fis_empresas_tecnospeed[]
  fis_nfe_produto_fornecedor fis_nfe_produto_fornecedor[]
  fis_nfe                    fis_nfe[]                    @relation("NfeEmpresaEmitente")
  fis_nfe_destinatario       fis_nfe[]                    @relation("NfeEmpresaDestinatario")
  fis_cte                    fis_cte[]                    @relation("CteEmpresaEmitente")
  fis_cte_destinatario       fis_cte[]                    @relation("CteEmpresaDestinatario")
  fis_cte_remetente          fis_cte[]                    @relation("CteEmpresaRemetente")
  fis_cte_tomador            fis_cte[]                    @relation("CteEmpresaTomador")
  fis_cte_subcontratada      fis_cte[]                    @relation("CteEmpresaSubcontratada")
  fis_regras_entrada_nfe     fis_regras_entrada_nfe[]
  fis_nfe_transportador      fis_nfe[]                    @relation("NfeEmpresaTransportadora")
  fis_integracao_documentos  fis_integracao_documentos[]
  fis_clientes               fis_clientes[]
}

/// Cadastro fiscal de clientes (tomadores/destinatários) vindos dos XMLs
model fis_clientes {
  id                       String         @id @default(uuid())
  dt_created               DateTime       @default(now())
  dt_updated               DateTime       @default(now()) @updatedAt
  id_fis_empresas          String
  fis_empresas             fis_empresas   @relation(fields: [id_fis_empresas], references: [id])
  id_externo               String?
  ds_nome                  String
  ds_documento             String?
  ds_ie                    String?
  ds_nome_fantasia         String?
  id_cidade                Int?
  sis_igbe_city            sis_igbe_city? @relation("FisClientesCidade", fields: [id_cidade], references: [id])
  ds_cep                   String?
  ds_logradouro            String?
  ds_numero                String?
  ds_complemento           String?
  ds_bairro                String?
  ds_uf                    String?
  ds_telefone              String?
  ds_email                 String?
  cd_municipio_ibge        String?
  ds_origem_cadastro       String?
  dt_ultima_ocorrencia_xml DateTime?

  tms_cargas tms_cargas[]

  @@unique([id_fis_empresas, ds_documento])
  @@index([id_fis_empresas])
}

model fis_segmentos_empresas {
  id                     String                   @id @default(uuid())
  dt_created             DateTime                 @default(now())
  dt_updated             DateTime                 @default(now()) @updatedAt
  ds_descricao           String
  fis_empresas           fis_empresas?            @relation(fields: [id_fis_empresas], references: [id])
  id_fis_empresas        String?
  fis_prd_segmentos      fis_prd_segmento[]       @relation("prd_segmento")
  fis_regras_entrada_nfe fis_regras_entrada_nfe[]

  sis_empresas sis_empresas[]
}

model fis_nfe_produto_fornecedor {
  id                String           @id @default(uuid())
  dt_created        DateTime         @default(now())
  dt_updated        DateTime         @updatedAt
  id_fis_empresas   String
  ds_ordem_origem   Int?
  fl_conversao      Boolean
  ds_conversao      String?
  id_nfe            String?
  fis_nfe           fis_nfe?         @relation(fields: [id_nfe], references: [id])
  fis_empresas      fis_empresas     @relation(fields: [id_fis_empresas], references: [id])
  id_fis_produto    String
  fis_produtos      fis_produtos     @relation(fields: [id_fis_produto], references: [id])
  id_fis_fornecedor String
  fis_fornecedor    fis_fornecedores @relation(fields: [id_fis_fornecedor], references: [id])
  ds_codigo_produto String?

  @@unique([id_fis_empresas, id_fis_produto, id_fis_fornecedor, ds_codigo_produto], name: "uniq_produto_fornecedor")
}

model fis_nfse {
