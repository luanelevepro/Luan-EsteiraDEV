}

model fis_sat_conferencia {
  id              String               @id @default(uuid())
  dt_created      DateTime             @default(now())
  dt_updated      DateTime             @default(now()) @updatedAt
  id_fis_empresas String?
  id_user         String?
  sis_profiles    sis_profiles?        @relation(fields: [id_user], references: [id])
  ds_filename     String?
  cd_file_hash    String?
  ds_status       SatConferenciaStatus @default(RECEBIDO)
  vl_rows_total   Int?                 @default(0)
  vl_errors_count Int?                 @default(0)
  ds_conteudo     Json?
  ds_message      Json?

  items fis_sat_conferencia_item[]

  @@index([id_fis_empresas])
}

model fis_sat_conferencia_item {
  id               String                    @id @default(uuid())
  id_conferencia   String
  ds_numero_row    Int
  id_fis_documento String?
  fis_documento    fis_documento?            @relation(fields: [id_fis_documento], references: [id])
  ds_status        SatConferenciaItemStatus?
  ds_message       String?
  dt_created       DateTime                  @default(now())

  conferencia fis_sat_conferencia @relation(fields: [id_conferencia], references: [id])

  @@index([id_conferencia])
}

model fis_auditoria_doc {
  id                 String        @id @default(uuid())
  dt_created         DateTime      @default(now())
  dt_updated         DateTime      @default(now()) @updatedAt
  id_fis_documento   String
  fis_documento      fis_documento @relation(fields: [id_fis_documento], references: [id])
  ds_tipo_doc        TipoDocumento
  js_inconsistencias Json
  id_nfe             String?
  fis_nfe            fis_nfe?      @relation(fields: [id_nfe], references: [id])
  id_nfse            String?
  fis_nfse           fis_nfse?     @relation(fields: [id_nfse], references: [id])
  id_cte             String?
  fis_cte            fis_cte?      @relation(fields: [id_cte], references: [id])
}

// Dicionário de tipos de inconsistência (regras)
model fis_tipo_inconsistencia {
  id                 String           @id @default(uuid())
  dt_created         DateTime         @default(now())
  dt_updated         DateTime         @default(now()) @updatedAt
  cd_codigo          String           @unique
  ds_descricao       String
  criticidade_padrao CriticidadeLevel @map("criticidade_padrao")
  ds_grupo           String?
  fl_ativo           Boolean          @default(true)
  ds_ordem_exibicao  Int?             @default(0)
  versao_regra       String?
  dt_inicio_vigencia DateTime?
  dt_fim_vigencia    DateTime?

  @@map("fis_tipo_inconsistencia")
}

enum CriticidadeLevel {
  INFO
  AVISO
  CRITICA
}

enum StatusAlteracaoSubcontratacao {
  PENDENTE
  APROVADO
  REJEITADO
  REVERTIDO
}
