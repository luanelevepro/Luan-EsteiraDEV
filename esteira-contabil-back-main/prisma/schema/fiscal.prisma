model fis_nfe {
  id                            String                       @id @default(uuid())
  dt_created                    DateTime                     @default(now())
  dt_updated                    DateTime                     @updatedAt
  id_fis_empresa_emitente       String?
  fis_empresa_emitente          fis_empresas?                @relation("NfeEmpresaEmitente", fields: [id_fis_empresa_emitente], references: [id])
  id_fis_empresa_destinatario   String? // empresa destinatária da NFe (se for o caso)
  fis_empresa_destinatario      fis_empresas?                @relation("NfeEmpresaDestinatario", fields: [id_fis_empresa_destinatario], references: [id])
  id_fis_empresa_transportadora String? // empresa transportadora da NFe (se for o caso)
  fis_empresa_transportadora    fis_empresas?                @relation("NfeEmpresaTransportadora", fields: [id_fis_empresa_transportadora], references: [id])
  ds_id_nfe                     String? // atributo infNFe.@Id (ex: "NFe4225068535…")
  ds_chave                      String?                      @unique
  js_nfes_referenciadas         Json? // array de chaves de NFes referenciadas
  ds_uf                         String? // <ide><cUF>
  cd_nf                         String? // <ide><cNF>
  ds_natureza_operacao          String? // <ide><natOp>
  ds_modelo                     String? // <ide><mod>
  ds_serie                      String? // <ide><serie>
  ds_numero                     String? // <ide><nNF>
  dt_emissao                    DateTime? // <ide><dhEmi>
  dt_saida_entrega              DateTime? // <ide><dhSaiEnt>
  cd_tipo_operacao              String? // <ide><idDest>
  cd_municipio                  String? // <ide><cMunFG>
  ds_fin_nfe                    String? // <ide><finNFe>
  vl_base_calculo               String? // <total><ICMSTot><vBC>
  vl_produto                    String? // <total><ICMSTot><vProd>
  vl_nf                         String? // <total><ICMSTot><vNF>
  vl_frete                      String? // <total><ICMSTot><vFrete>
  vl_seg                        String? // <total><ICMSTot><vSeg>
  vl_desc                       String? // <total><ICMSTot><vDesc>
  vl_ii                         String? // <total><ICMSTot><vII>
  vl_ipi                        String? // <total><ICMSTot><vIPI>
  vl_ipidevol                   String? // <total><ICMSTot><vIPIDevol>
  vl_pis                        String? // <total><ICMSTot><vPIS>
  vl_cofins                     String? // <total><ICMSTot><vCOFINS>
  vl_outros                     String? // <total><ICMSTot><vOutro>
  vl_bc                         String? // <total><ICMSTot><vBC>
  vl_icms                       String? // <total><ICMSTot><vICMS>
  vl_icms_desoner               String? // <total><ICMSTot><vICMSDeson>
  ds_base_calculo_mono_total    String? // <prod><vBC><vMono>
  ds_porcentagem_mono_total     String? // <prod><pMono>
  js_itens                      Json?
  ds_documento_emitente         String? // <emit><CNPJ> ou <emit><CPF>
  ds_razao_social_emitente      String? // <emit><xNome>
  cd_crt_emitente               String? // <emit><CRT>
  ds_uf_emitente                String?
  ds_municipio_emitente         String?
  ds_documento_destinatario     String? // <dest><CNPJ> ou <dest><CPF>
  ds_razao_social_destinatario  String? // <dest><xNome>
  ds_documento_transportador    String?
  ds_razao_social_transportador String?
  id_fis_fornecedor             String? // fornecedor que emitiu a NFe
  fis_fornecedor                fis_fornecedores?            @relation(fields: [id_fis_fornecedor], references: [id])
  fis_nfe_itens                 fis_nfe_itens[]
  fis_documento                 fis_documento[]
  fis_nfe_produto_fornecedor    fis_nfe_produto_fornecedor[]
  fis_integracao_documentos     fis_integracao_documentos[]
  fis_documento_dfe             fis_documento_dfe[]
  fis_auditoria_doc             fis_auditoria_doc[]
  tms_cargas_nfe                tms_cargas_nfe[]
  tms_entregas_nfe              tms_entregas_nfe[]

  @@unique([id_fis_empresa_destinatario, ds_numero, dt_emissao], name: "uniq_nfe_por_empresa_destinatario")
  @@unique([id_fis_empresa_emitente, ds_numero, dt_emissao], name: "uniq_nfe_por_empresa_emitente")
}

