model fis_nfe_itens_alter_entrada {
  id                      String                  @id @default(uuid())
  dt_created              DateTime                @default(now())
  dt_updated              DateTime                @updatedAt
  id_nfe_item             String
  fis_nfe_itens           fis_nfe_itens           @relation(fields: [id_nfe_item], references: [id])
  id_regra_nfe_entrada    String?
  fis_regras_entrada_nfe  fis_regras_entrada_nfe? @relation(fields: [id_regra_nfe_entrada], references: [id])
  fl_conversao            Boolean?
  ds_conversao            String?
  ds_quantidade_alterada  String?
  id_cfop_alterado        String?
  sis_cfop                sis_cfop?               @relation("CfopAlterado", fields: [id_cfop_alterado], references: [id])
  ds_codigo_cfop_alterado String? // dado da tabela de sis_cfop que é uma replicação de ds_codigo
  id_cst_gerado           String?
  sis_cst                 sis_cst?                @relation("CstGerado", fields: [id_cst_gerado], references: [id])
  ds_codigo_cst_gerado    String? // dado da tabela de sis_cst que é uma replicação de ds_codigo
  id_produto_alterado     String?
  fis_produtos            fis_produtos?           @relation(fields: [id_produto_alterado], references: [id])
  cd_produto_alterado     String? // dado da tabela de fis_produtos que é uma replicação de id_externo

  @@unique(id_nfe_item, name: "uniq_alteracao_por_item_nfe")
}

model fis_cte {
  id                            String                         @id @default(uuid())
  dt_created                    DateTime                       @default(now())
  dt_updated                    DateTime                       @updatedAt
  id_fis_empresa_emitente       String?
  fis_empresa_emitente          fis_empresas?                  @relation("CteEmpresaEmitente", fields: [id_fis_empresa_emitente], references: [id])
  id_fis_empresa_destinatario   String? // empresa destinatária da NFe (se for o caso)
  fis_empresa_destinatario      fis_empresas?                  @relation("CteEmpresaDestinatario", fields: [id_fis_empresa_destinatario], references: [id])
  id_fis_empresa_remetente      String? // empresa remetente do CTe (se for o caso)
  fis_empresa_remetente         fis_empresas?                  @relation("CteEmpresaRemetente", fields: [id_fis_empresa_remetente], references: [id])
  id_fis_empresa_tomador        String? // empresa tomadora do serviço de transporte (se for o caso)
  fis_empresa_tomador           fis_empresas?                  @relation("CteEmpresaTomador", fields: [id_fis_empresa_tomador], references: [id])
  id_fis_empresa_subcontratada  String? // empresa subcontratada do serviço de transporte (se for o caso)
  fis_empresa_subcontratada     fis_empresas?                  @relation("CteEmpresaSubcontratada", fields: [id_fis_empresa_subcontratada], references: [id])
  id_fis_fornecedor             String? // fornecedor que emitiu o CTe
  fis_fornecedor                fis_fornecedores?              @relation(fields: [id_fis_fornecedor], references: [id])
  ds_id_cte                     String                         @unique // InfCte.@Id
  ds_chave                      String                         @unique // Chave de acesso (44 dígitos)
  js_chaves_nfe                 Json? // Array de chaves de acesso das NFes associadas (infNFe)
  js_documentos_anteriores      Json? // <docAnt>
  ds_observacao                 String?
  js_documentos_autorizados     Json?
  js_placas_veiculos            Json?
  id_motorista                  String?
  tms_motoristas                tms_motoristas?                @relation(fields: [id_motorista], references: [id])
  ds_nome_motorista             String?
  ds_documento_motorista        String?
  ds_uf                         String? // <ide><cUF>
  cd_ibge                       String? // <ide><cMun>
  cd_cte                        String? // <ide><cCT>
  ds_cfop                       String? // <ide><CFOP>
  ds_icms_tag                   String? // <ide><ICMS>
  ds_natureza_operacao          String? // <ide><natOp>
  ds_modelo                     Int? // <ide><mod>
  ds_serie                      Int? // <ide><serie>
  ds_numero                     String? // <ide><nCT>
  dt_emissao                    DateTime? // <ide><dhEmi>
  ds_tp_cte                     Int? // <ide><tpCTe>
  ds_modal                      String? // <ide><modal>
  ds_tp_serv                    Int? // <ide><tpServ>
  cd_mun_env                    String? // <ide><cMunEnv>
  ds_nome_mun_env               String? // <ide><xMunEnv>
  ds_uf_env                     String? // <ide><UFEnv>
  cd_mun_ini                    String? // <ide><cMunIni>
  ds_nome_mun_ini               String? // <ide><xMunIni>
  ds_uf_ini                     String? // <ide><UFIni>
  cd_mun_fim                    String? // <ide><cMunFim>
  ds_nome_mun_fim               String? // <ide><xMunFim>
  ds_uf_fim                     String? // <ide><UFFim>
  ds_retira                     Int? // <ide><retira>
  ds_ind_ie_toma                Int? // <ide><indIEToma>
  ds_documento_emitente         String? // <emit><CNPJ> ou <emit><CPF>
  ds_razao_social_emitente      String? // <emit><xNome>
  ds_documento_remetente        String? // <toma><CNPJ> ou <toma><CPF>
  ds_razao_social_remetente     String? // <toma><xNome>
  ds_endereco_remetente         String? // endereço do remetente (toma): rem.enderReme (xLgr, nro, xBairro, xMun, UF, CEP)
  ds_complemento_remetente      String? // complemento (xCpl) do endereço remetente
  ds_documento_destinatario     String? // <dest><CNPJ> ou <dest><CPF>
  ds_razao_social_destinatario  String? // <dest><xNome>
  ds_documento_tomador          String? // <toma><CNPJ> ou <toma><CPF> (ou toma4)
  ds_razao_social_tomador       String? // <toma><xNome>
  ds_documento_expedidor        String? // <exped><CNPJ> ou <exped><CPF>
  ds_razao_social_expedidor     String? // <exped><xNome>
  ds_documento_recebedor        String? // <receb><CNPJ> ou <receb><CPF>
  ds_razao_social_recebedor     String? // <receb><xNome>
  ds_endereco_destino           String? // endereço do destino da entrega (receb.enderReceb ou dest.enderDest: xLgr, nro, xBairro)
  ds_complemento_destino        String? // complemento (xCpl) do endereço destino
  ds_razao_social_subcontratada String?
  ds_documento_subcontratada    String?
  vl_total                      String? // <vPrest><vTPrest>
  vl_rec                        String? // <vPrest><vRec>
  vl_total_trib                 String? // valor total dos tributos (<imp><vTotTrib>)
  ds_cst_tributacao             String? // <imp><ICMS><CST>
  vl_base_calculo_icms          String? // <imp><ICMS><vBC>
  vl_icms                       String? // <imp><ICMS><vICMS>
  cd_icms                       String? // <imp><ICMS><CST>
  vl_porcentagem_icms           String? // <imp><ICMS><pICMS>
  fis_cte_comp_carga            fis_cte_comp_carga[]
  fis_cte_carga                 fis_cte_carga[]
  fis_documento                 fis_documento[]
  fis_integracao_documentos     fis_integracao_documentos[]
  fis_documento_dfe             fis_documento_dfe[]
  fis_auditoria_doc             fis_auditoria_doc[]
  fis_cte_subcontratacao_alters fis_cte_subcontratacao_alter[]
  tms_cargas_ctes               tms_cargas_cte[]
  tms_entregas_cte              tms_entregas_cte[]

  @@unique([id_fis_empresa_emitente, ds_numero, dt_emissao], name: "uniq_cte_por_empresa_emitente")
  @@unique([id_fis_empresa_destinatario, ds_numero, dt_emissao], name: "uniq_cte_por_empresa_destinatario")
  @@index([ds_chave])
}

model fis_cte_subcontratacao_alter {
  id         String   @id @default(uuid())
  dt_created DateTime @default(now())
  dt_updated DateTime @updatedAt
  // Documento modificado
  id_fis_cte String
  fis_cte    fis_cte  @relation(fields: [id_fis_cte], references: [id])

  // Valores originais (antes da alteração)
  ds_documento_subcontratada_original    String?
  ds_razao_social_subcontratada_original String?
  id_fis_empresa_subcontratada_original  String?

  // Valores alterados
