/// Logs / histórico de integrações de documentos (NFe / NFSe / CTe / outros)
model fis_integracao_documentos {
  id         String   @id @default(uuid())
  dt_created DateTime @default(now())
  dt_updated DateTime @default(now()) @updatedAt

  /// Empresa dona do registro (contexto)
  id_fis_empresas String
  fis_empresas    fis_empresas @relation(fields: [id_fis_empresas], references: [id])

  /// Vínculos opcionais para facilitar correlação
  id_fis_documento String?
  fis_documento    fis_documento? @relation(fields: [id_fis_documento], references: [id])

  id_fis_nfe String?
  fis_nfe    fis_nfe? @relation(fields: [id_fis_nfe], references: [id])

  id_fis_nfse String?
  fis_nfse    fis_nfse? @relation(fields: [id_fis_nfse], references: [id])

  id_fis_cte String?
  fis_cte    fis_cte? @relation(fields: [id_fis_cte], references: [id])

  /// Usuário que iniciou/acionou a integração (se aplicável)
  id_profile  String?
  sis_profile sis_profiles? @relation(fields: [id_profile], references: [id])

  /// Ação e status do log
  action IntegracaoAction
  status IntegracaoStatus @default(PENDING)

  /// Destino / sistema alvo (ex: ONVIO, DOMINIO, OUTRO)
  ds_destination String?
  /// ID de lote retornado pelo sistema externo (quando aplicável)
  ds_lote_id     String?
  /// Nome do arquivo enviado
  ds_filename    String?

  /// Conteúdo bruto enviado (XML / JSON) e resposta recebida
  ds_raw      String? // armazenar raw do documento enviado
  ds_response String? // resposta recebida do integrador

  /// Número de tentativas e timestamps de envio
  attempts    Int       @default(0)
  dt_sent     DateTime?
  dt_finished DateTime?

  /// Dados extras estruturados
  js_metadata Json?

  @@index([id_fis_empresas])
  @@index([status])
}

/// Ações possíveis para um registro de integração
enum IntegracaoAction {
  SEND
  REVERT
  OTHER
}

/// Status do processamento de integração
enum IntegracaoStatus {
  PENDING
  SENT
  SUCCESS
  FAILED
}

