  fis_regras_entrada_nfe_cfop_origem fis_regras_entrada_nfe_cfop_origem[]

  fis_regras_entrada_nfe fis_regras_entrada_nfe[] @relation("CfopEntrada")

  fis_regras_entrada_nfe_gerado fis_regras_entrada_nfe[] @relation("CfopGerado")

  fis_nfe_itens_alter fis_nfe_itens_alter_entrada[] @relation("CfopAlterado")
}

model sis_emb_marcas_carrocerias {
  id       Int    @id @default(autoincrement())
  cd_marca Int    @unique
  ds_nome  String
}

model sis_certificados {
  id              String        @id @default(uuid())
  dt_created      DateTime      @default(now())
  dt_updated      DateTime      @default(now()) @updatedAt
  ds_nome         String
  ds_nome_arquivo String
  ds_arquivo      String
  ds_senha        String
  dt_expiracao    DateTime
  id_usuario      String
  ds_pfx          String
  id_empresa      String?
  sis_empresas    sis_empresas? @relation(fields: [id_empresa], references: [id], onDelete: Cascade)
}

model sis_tipo_integracao {
  id             String           @id @default(uuid())
  dt_created     DateTime         @default(now())
  dt_updated     DateTime         @updatedAt
  ds_nome        String
  sis_integracao sis_integracao[]
}

model sis_integracao {
  id                    String                  @id @default(uuid())
  dt_created            DateTime                @default(now())
  dt_updated            DateTime                @updatedAt
  ds_nome               String
  ds_descricao          String?
  fl_is_para_escritorio Boolean?                @default(false)
  fl_is_para_sistema    Boolean?                @default(false)
  id_tipo_integracao    String
  js_tipo_integracao    sis_tipo_integracao     @relation(fields: [id_tipo_integracao], references: [id])
  sis_integracao_campos sis_integracao_campos[]
  sis_integracao_config sis_integracao_config[]

  adm_consumo_integracao adm_consumo_integracao[]
}

model sis_integracao_campos {
  id                   String         @id @default(uuid())
  dt_created           DateTime       @default(now())
  dt_updated           DateTime       @updatedAt
  ds_campo_nome        String
  ds_campo_placeholder String?
  ds_campo_tipo        String
  ds_campo_ordem       Int
  id_integracao        String
  js_integracao        sis_integracao @relation(fields: [id_integracao], references: [id], onDelete: Cascade)
}

model sis_integracao_config {
  id                String         @id @default(uuid())
  dt_created        DateTime       @default(now())
  dt_updated        DateTime       @updatedAt
  ds_valores_config Json
  id_integracao     String
  js_integracao     sis_integracao @relation(fields: [id_integracao], references: [id], onDelete: Cascade)
  id_sis_empresas   String
  js_empresas       sis_empresas   @relation(fields: [id_sis_empresas], references: [id])

  @@unique([id_sis_empresas, id_integracao], name: "ux_empresa_integracao")
}

model sis_municipio_ambiente_nacional {
  id             String   @id @default(uuid())
  dt_created     DateTime @default(now())
  dt_updated     DateTime @updatedAt
  ds_nome        String
  ds_uf          String
  ds_ibge_codigo String   @unique
  is_ativo       Boolean  @default(true)
}

enum ModuleType {
  SISTEMA
  ADMINISTRATIVO
  CONTABILIDADE
  FISCAL
  FINANÇAS
  FATURAMENTO
  ESTOQUES
  RECURSOS_HUMANOS
  CONTROLADORIA
  ADM_SISTEMA
  ADM_ESCRITORIO
  ADM_EMPRESA
  EMBARCADOR
  TMS
  REFORMA_TRIBUTARIA
}

model sis_modules {
  id                   String                 @id @default(uuid())
  ds_module            String
  dt_created           DateTime               @default(now())
  sis_profiles_modules sis_profiles_modules[]
  sis_empresas_modules sis_empresas_modules[]
}

model sis_profiles_modules {
  profile      sis_profiles @relation(fields: [id_profile], references: [id])
  id_profile   String
  module       sis_modules  @relation(fields: [id_module], references: [id])
  id_module    String
  dt_ativacao  DateTime     @default(now())
  is_activated Boolean      @default(false)
  dt_created   DateTime     @default(now())
  dt_updated   DateTime

  @@id([id_profile, id_module])
}

model sis_empresas_modules {
  empresa      sis_empresas @relation(fields: [id_empresa], references: [id])
  id_empresa   String
  module       sis_modules  @relation(fields: [id_module], references: [id])
  id_module    String
  dt_ativacao  DateTime     @default(now())
  is_activated Boolean      @default(false)
  dt_created   DateTime     @default(now())
  dt_updated   DateTime

  @@id([id_empresa, id_module])
}

enum CrtType {
  SIMPLES
  NORMAL
  MEI
}

model sis_regions {
  id              Int               @id
  dt_created      DateTime          @default(now())
  dt_updated      DateTime          @default(now()) @updatedAt
  ds_region       String            @db.VarChar(255)
  ds_region_clean String?           @db.VarChar(255)
  js_mesoregions  sis_mesoregions[]
}

model sis_mesoregions {
  id                          Int                           @id
  dt_created                  DateTime                      @default(now())
  dt_updated                  DateTime                      @default(now()) @updatedAt
  ds_mesoregion               String                        @db.VarChar(255)
  ds_mesoregion_clean         String?                       @db.VarChar(255)
  id_region                   Int
  js_region                   sis_regions                   @relation(fields: [id_region], references: [id])
  js_microregions             sis_microregions[]
  emb_combustivel_mesorregiao emb_combustivel_mesorregiao[]
}

model sis_microregions {
  id                          Int                           @id
  dt_created                  DateTime                      @default(now())
  dt_updated                  DateTime                      @default(now()) @updatedAt
  ds_microregion              String                        @db.VarChar(255)
  ds_microregion_clean        String?                       @db.VarChar(255)
  id_mesoregion               Int
  js_mesoregion               sis_mesoregions               @relation(fields: [id_mesoregion], references: [id])
  js_ufs                      sis_ibge_uf[]
  emb_combustivel_microregiao emb_combustivel_microregiao[]
}

model sis_ibge_uf {
  id                     Int                      @id
  dt_created             DateTime                 @default(now())
  dt_updated             DateTime                 @default(now()) @updatedAt
  ds_state               String                   @db.VarChar(255)
  ds_state_clean         String?                  @db.VarChar(255)
  ds_uf                  String
  js_ibge_city           sis_igbe_city[]
  emb_ibge_uf            emb_ibge_uf[]
  id_microregion         Int?
  js_microregion         sis_microregions?        @relation(fields: [id_microregion], references: [id])
  emb_combustivel_estado emb_combustivel_estado[]

  sis_grupos_tributarios_vigencia sis_grupos_tributarios_vigencia[]
  sis_ibge_uf_vigencia            sis_ibge_uf_vigencia[]
}

model sis_igbe_city {
  id                        Int                         @id
  dt_created                DateTime                    @default(now())
  dt_updated                DateTime                    @default(now()) @updatedAt
  ds_city                   String
  ds_city_clean             String?                     @db.VarChar(255)
  js_uf                     sis_ibge_uf                 @relation(fields: [id_ibge_uf], references: [id])
  id_ibge_uf                Int
  emb_ibge_cidades          emb_ibge_cidades[]
  emb_postos_coleta         emb_postos_coleta[]
  emb_combustivel_municipio emb_combustivel_municipio[]
  tms_cargas_origem         tms_cargas[]                @relation("OrigemCarga")
  tms_cargas_destino        tms_cargas[]                @relation("DestinoCarga")
  tms_entregas_destino      tms_entregas[]              @relation("DestinoEntrega")
  tmsMotoristas             tms_motoristas[]
  fis_clientes_cidade       fis_clientes[]              @relation("FisClientesCidade")
  tms_embarcadores_cidade   tms_embarcadores[]          @relation("TmsEmbarcadoresCidade")
}

model sis_ibge_uf_vigencia {
  id                           String      @id @default(uuid())
  dt_created                   DateTime    @default(now())
  dt_updated                   DateTime    @default(now()) @updatedAt
  dt_vigencia                  DateTime
  vl_percentual_ipva_carros    Decimal     @db.Decimal(10, 6)
  vl_percentual_ipva_caminhoes Decimal     @db.Decimal(10, 6)
  vl_icms_proprio              Decimal     @default(1) @db.Decimal(10, 6)
  excecoes_uf_interestadual    Json?
  icms_interestadual           Decimal?    @db.Decimal(10, 2)
  vl_icms_excecao              Decimal?    @db.Decimal(10, 2)
  credito_icms_combustivel     Boolean     @default(false)
  credito_icms_imobilizado     Boolean     @default(false)
  credito_icms_manutencao      Boolean     @default(false)
  credito_icms_pneu            Boolean     @default(false)
  id_sis_ibge_uf               Int
  js_sis_ibge_uf               sis_ibge_uf @relation(fields: [id_sis_ibge_uf], references: [id])

  @@unique([id_sis_ibge_uf, dt_vigencia])
}

model sis_armadores {
