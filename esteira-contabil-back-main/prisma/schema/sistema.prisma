model sis_cst {
  id           String   @id @default(uuid())
  dt_created   DateTime @default(now())
  dt_updated   DateTime @default(now()) @updatedAt
  ds_descricao String
  ds_codigo    String?

  fis_regras_entrada_nfe_cst_origem fis_regras_entrada_nfe_cst_origem[]

