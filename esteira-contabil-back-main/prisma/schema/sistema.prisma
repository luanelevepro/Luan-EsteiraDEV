model sis_profiles {
  id                        String                      @id @default(uuid())
  dt_created                DateTime?                   @default(now())
  dt_updated                DateTime                    @default(now()) @updatedAt
  ds_name                   String?
  ds_email                  String                      @unique
  is_confirmed              Boolean                     @default(false)
  is_admin                  Boolean                     @default(false)
  js_access                 sis_access[]
  js_empresas               sis_empresas[]
  js_empresas_bloqueadas    sis_empresas[]              @relation("bloqueados_profiles_empresas")
  sis_profiles_notificacoes sis_profiles_notificacoes[]
  fis_integracao_documentos fis_integracao_documentos[]
  sis_profiles_modules      sis_profiles_modules[]

  fis_sat_conferencia           fis_sat_conferencia[]
  fis_documento_historico       fis_documento_historico[]
  fis_cte_alteracao_aprovador   fis_cte_subcontratacao_alter[] @relation("Aprovador")
  fis_cte_alteracao_solicitante fis_cte_subcontratacao_alter[] @relation("Solicitante")
  tms_fechamentos_aprovador     tms_fechamentos[]              @relation("FechamentoAprovador")
}

enum TiposNotificacoes {
  WARN
  INFO
  SUCCESS
  ERROR
  DEBUG

  @@map("tipos_notifacoes")
}

model sis_profiles_notificacoes {
  id           String            @id @default(uuid())
  id_profile   String
  js_profile   sis_profiles      @relation(fields: [id_profile], references: [id], onDelete: Cascade)
  ds_titulo    String
  ds_descricao String?
  cd_tipo      TiposNotificacoes
  dt_created   DateTime          @default(now())
  dt_updated   DateTime          @default(now()) @updatedAt
}

model sis_access {
  id             String        @id @default(uuid())
  dt_created     DateTime      @default(now())
  dt_updated     DateTime      @default(now()) @updatedAt
  id_profiles    String?       @unique
  id_empresas    String?       @unique
  dt_faturamento DateTime?
  js_modules     ModuleType[]
  js_profiles    sis_profiles? @relation(fields: [id_profiles], references: [id], onDelete: Cascade)
  sis_empresas   sis_empresas? @relation(fields: [id_empresas], references: [id], onDelete: Cascade)
}

model sis_empresas {
  id                         String                       @id @default(uuid())
  id_externo                 String?
  dt_created                 DateTime                     @default(now())
  dt_updated                 DateTime                     @default(now()) @updatedAt
  ds_razao_social            String?
  ds_fantasia                String?
  ds_apelido                 String?
  ds_nome                    String?
  ds_municipio               String?
  ds_documento               String                       @unique
  is_ativo                   Boolean?
  dt_ativacao                DateTime?
  dt_inativacao              DateTime?
  ds_url                     String?
  ds_integration_key         String?
  ds_cnae                    String?
  ds_inscricao_estadual      String?
  ds_inscricao_municipal     String?
  ds_uf                      String?
  is_escritorio              Boolean                      @default(false)
  id_segmento                String?
  js_segmento                fis_segmentos_empresas?      @relation(fields: [id_segmento], references: [id])
  id_regime_tributario       String?
  js_regime_tributario       sis_regimes_tributarios?     @relation(fields: [id_regime_tributario], references: [id])
  js_profiles                sis_profiles[]
  js_access                  sis_access[]
  id_escritorio              String?
  js_escritorio              sis_empresas?                @relation("Escritorio", fields: [id_escritorio], references: [id])
  js_empresas                sis_empresas[]               @relation("Escritorio")
  js_bloqueados              sis_profiles[]               @relation("bloqueados_profiles_empresas")
  rh_empresas                rh_empresas[]
  fis_empresas               fis_empresas?
  emb_empresas               emb_empresas?
  js_certificados            sis_certificados[]
  con_empresas               con_empresas[]
  sis_integracao_config      sis_integracao_config[]
  adm_empresas               adm_empresas[]
  sis_empresas_modules       sis_empresas_modules[]
  js_tms_empresas            tms_empresas?
  sis_colunas_personalizadas sis_colunas_personalizadas[]
  tms_import_layouts         tms_import_layout[]
}

model sis_regimes_tributarios {
  id                            String                          @id @default(uuid())
  dt_created                    DateTime                        @default(now())
  dt_updated                    DateTime                        @default(now()) @updatedAt
  ds_descricao                  String
  ds_crt                        CrtType?
  emb_empresas                  emb_empresas?                   @relation(fields: [emb_empresasId], references: [id])
  emb_empresasId                String?
  // emb_transportadoras_historico emb_transportadoras_historico[]
  emb_transportadoras_historico emb_transportadoras_historico[]
  fis_regras_entrada_nfe        fis_regras_entrada_nfe[]        @relation(name: "RegimeTributarioDest")

  fis_regras_entrada_nfe_emit fis_regras_entrada_nfe[] @relation(name: "RegimeTributarioEmit")

  sis_empresas sis_empresas[]
}

model sis_grupos_tributarios {
  id      String @id @default(uuid())
  ds_nome String @db.VarChar(50)

  emb_segmento_carga emb_segmento_carga[]

  sis_grupos_tributarios_vigencia sis_grupos_tributarios_vigencia[]
}

model sis_grupos_tributarios_vigencia {
  id                          String                 @id @default(uuid())
  id_sis_grupos_tributarios   String
  js_sis_grupos_tributarios   sis_grupos_tributarios @relation(fields: [id_sis_grupos_tributarios], references: [id])
  dt_vigencia                 DateTime
  id_sis_ibge_uf_origem_carga Int
  js_sis_ibge_uf_origem_carga sis_ibge_uf            @relation(fields: [id_sis_ibge_uf_origem_carga], references: [id])
  vl_cst                      Int
  fl_dif_icms                 Boolean                @default(false)

  @@unique([id_sis_grupos_tributarios, dt_vigencia])
}

model sis_simples_nacional {
  id                         String                       @id @default(uuid())
  cd_simples                 Int                          @unique
  ds_nome                    String                       @db.VarChar(50)
  sis_simples_nacional_faixa sis_simples_nacional_faixa[]
}

model sis_simples_nacional_faixa {
  id                                              String                                            @id @default(uuid())
  ds_faixa                                        String                                            @db.VarChar(50)
  id_sis_simples_nacional                         String
  js_sis_simples_nacional                         sis_simples_nacional                              @relation(fields: [id_sis_simples_nacional], references: [id])
  sis_simples_nacional_vigencia                   sis_simples_nacional_vigencia[]
  sis_simples_nacional_divisao_taxas_prm_vigencia sis_simples_nacional_divisao_taxas_prm_vigencia[]
}

model sis_simples_nacional_vigencia {
  id                String   @id @default(uuid())
  dt_vigencia       DateTime
  vl_receita_minima Decimal? @db.Decimal(14, 2)
  vl_receita_maxima Decimal? @db.Decimal(14, 2)
  vl_aliquota       Decimal  @db.Decimal(7, 4)
  vl_dedutivel      Decimal  @db.Decimal(14, 2)
  dt_created        DateTime @default(now())
  dt_updated        DateTime @default(now()) @updatedAt

  id_sis_simples_nacional_faixa    String
  js_id_sis_simples_nacional_faixa sis_simples_nacional_faixa @relation(fields: [id_sis_simples_nacional_faixa], references: [id])

  @@unique([id_sis_simples_nacional_faixa, dt_vigencia])
}

model sis_simples_nacional_divisao_taxas_prm_vigencia {
  id                String   @id @default(uuid())
  dt_vigencia       DateTime
  vl_porcent_cpp    Decimal  @db.Decimal(14, 2)
  vl_porcent_csll   Decimal  @db.Decimal(14, 2)
  vl_porcent_irpj   Decimal  @db.Decimal(14, 2)
  vl_porcent_pis    Decimal  @db.Decimal(14, 2)
  vl_porcent_cofins Decimal  @db.Decimal(14, 2)
  vl_porcent_icms   Decimal  @db.Decimal(14, 2)

  dt_created DateTime @default(now())
  dt_updated DateTime @default(now()) @updatedAt

  id_sis_simples_nacional_faixa String
  js_sis_simples_nacional_faixa sis_simples_nacional_faixa @relation(fields: [id_sis_simples_nacional_faixa], references: [id])

  @@unique([id_sis_simples_nacional_faixa, dt_vigencia])
}

