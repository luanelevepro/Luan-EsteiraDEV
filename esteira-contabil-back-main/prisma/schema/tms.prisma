// === FECHAMENTO DE MOTORISTAS ===

model tms_fechamentos {
  id                       String           @id @default(uuid())
  dt_created               DateTime         @default(now())
  dt_updated               DateTime         @default(now()) @updatedAt
  id_tms_empresa           String
  id_tms_motoristas        String
  competencia              String // YYYY-MM
  ds_status                StatusFechamento @default(ABERTO)
  vl_total_frete           Decimal          @default(0) @db.Decimal(14, 2)
  vl_total_adiantamentos   Decimal          @default(0) @db.Decimal(14, 2)
  vl_total_despesas        Decimal          @default(0) @db.Decimal(14, 2)
  vl_total_descontos       Decimal          @default(0) @db.Decimal(14, 2)
  vl_total_proventos       Decimal?         @db.Decimal(14, 2)
  vl_liquido               Decimal          @default(0) @db.Decimal(14, 2)
  dt_fechamento            DateTime?
  id_sis_profile_aprovador String?

  tms_empresas            tms_empresas              @relation(fields: [id_tms_empresa], references: [id])
  tms_motoristas          tms_motoristas            @relation(fields: [id_tms_motoristas], references: [id])
  sis_profile_aprovador   sis_profiles?             @relation("FechamentoAprovador", fields: [id_sis_profile_aprovador], references: [id])
  tms_fechamento_viagens  tms_fechamento_viagens[]
  tms_fechamento_cargas   tms_fechamento_cargas[]
  tms_fechamentos_titulos tms_fechamentos_titulos[]

  @@unique([id_tms_empresa, id_tms_motoristas, competencia])
  @@index([id_tms_empresa])
  @@index([competencia])
  @@index([ds_status])
}

model tms_fechamento_viagens {
  id            String   @id @default(uuid())
  id_fechamento String
  id_viagem     String
  dt_vinculacao DateTime @default(now())

  tms_fechamentos tms_fechamentos @relation(fields: [id_fechamento], references: [id], onDelete: Cascade)
  tms_viagens     tms_viagens     @relation(fields: [id_viagem], references: [id])

  @@unique([id_fechamento, id_viagem])
  @@index([id_fechamento])
  @@index([id_viagem])
}

model tms_fechamento_cargas {
  id         String   @id @default(uuid())
  dt_created DateTime @default(now())

  id_fechamento String
  id_carga      String

  id_viagem    String?
  nr_sequencia Int?

  id_motorista_veiculo  String?
  dt_entregue_em        DateTime?
  ds_status_carga       StatusCarga
  fl_deslocamento_vazio Boolean     @default(false)

  vl_base_comissao Decimal? @db.Decimal(14, 2)

  tms_fechamentos tms_fechamentos @relation(fields: [id_fechamento], references: [id], onDelete: Cascade)
  tms_cargas      tms_cargas      @relation(fields: [id_carga], references: [id], onDelete: Cascade)
  tms_viagens     tms_viagens?    @relation(fields: [id_viagem], references: [id])

  @@unique([id_fechamento, id_carga])
  @@index([id_fechamento])
  @@index([id_carga])
  @@index([id_viagem])
}

model tms_fechamentos_titulos {
  id                    String  @id @default(uuid())
  id_fechamento         String
  id_tms_viagem_despesa String
  id_viagem             String?
  nr_sequencia          Int?

  tms_fechamentos     tms_fechamentos     @relation(fields: [id_fechamento], references: [id], onDelete: Cascade)
  tms_viagem_despesas tms_viagem_despesas @relation(fields: [id_tms_viagem_despesa], references: [id])
  tms_viagens         tms_viagens?        @relation(fields: [id_viagem], references: [id])

  @@unique([id_fechamento, id_tms_viagem_despesa])
  @@index([id_fechamento])
}

